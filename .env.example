# Local development defaults. The UI clearly labels this mode.
ECHO_COMPUTE_MODE=local
ECHO_STORAGE_MODE=local
ECHO_DATA_BACKEND=file
ECHO_DATA_FILE=.data/echo.json
# Recommended separate 32+ character secret for signing device sessions.
# ECHO_SESSION_SECRET=replace-with-a-random-secret

# Phase 2 recoverable identity. Guest mode remains the zero-config default.
NEXT_PUBLIC_ECHO_AUTH_MODE=guest
# Enable after creating a Clerk application or installing Clerk from Vercel Marketplace:
# NEXT_PUBLIC_ECHO_AUTH_MODE=clerk
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/
# NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/
# NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/

# Production database
# ECHO_DATA_BACKEND=postgres
# DATABASE_URL=postgres://user:password@host:5432/echo

# 0G Compute Router — testnet
# Create and fund an API key at https://pc.testnet.0g.ai
# ECHO_COMPUTE_MODE=0g
# ZERO_G_COMPUTE_API_KEY=sk-...
ZERO_G_COMPUTE_BASE_URL=https://router-api-testnet.integratenetwork.work/v1
ZERO_G_COMPUTE_MODEL=zai-org/GLM-5-FP8

# 0G Storage — Galileo testnet + Turbo
# ECHO_STORAGE_MODE=0g
# ZERO_G_STORAGE_PRIVATE_KEY=0x...
# Generate with: node -e "console.log('0x'+require('crypto').randomBytes(32).toString('hex'))"
# ZERO_G_MEMORY_ENCRYPTION_KEY=0x...
ZERO_G_STORAGE_RPC_URL=https://evmrpc-testnet.0g.ai
ZERO_G_STORAGE_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai
ZERO_G_CHAIN_EXPLORER_URL=https://chainscan-galileo.0g.ai
