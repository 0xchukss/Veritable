# Local development defaults. The UI clearly labels this mode.
VERITABLE_STORAGE_MODE=local

# Durable index used by public /verify/:id URLs.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/veritable

# 0G Storage — Galileo testnet + Turbo
# Set VERITABLE_STORAGE_MODE=0g and provide a funded wallet + fresh encryption key.
# VERITABLE_STORAGE_MODE=0g
# ZERO_G_STORAGE_PRIVATE_KEY=0x...
# Generate with: node -e "console.log('0x'+require('crypto').randomBytes(32).toString('hex'))"
# ZERO_G_CREDENTIAL_ENCRYPTION_KEY=0x...
# Used to authenticate short-lived browser-to-server 0G Compute receipts.
# Generate with the same command above; keep it separate in production.
# VERITABLE_RECEIPT_SECRET=...
ZERO_G_STORAGE_RPC_URL=https://evmrpc-testnet.0g.ai
ZERO_G_STORAGE_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai
ZERO_G_CHAIN_EXPLORER_URL=https://chainscan-galileo.0g.ai

# 0G Compute Router. Set the RPC to the same network as the Router.
# ZERO_G_COMPUTE_API_KEY=...
# ZERO_G_COMPUTE_BASE_URL=https://router-api-testnet.integratenetwork.work/v1
# ZERO_G_COMPUTE_MODEL=qwen/qwen2.5-omni-7b
# ZERO_G_COMPUTE_RPC_URL=https://evmrpc-testnet.0g.ai

# Optional Clerk account identity (Phase 3)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
